# KaagazAI — server-side AI keys (never exposed to the browser)
#
# Primary reader: Google Gemini 2.5 Flash
#   Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Failover reader: Groq (Llama 4 Scout vision)
#   Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Optional: force built-in sample data even if keys are set (demo without burning quota)
# KAAGAZ_MOCK=1

# ── Khata persistence (optional locally, required on Vercel) ─────────────
# Create a free Supabase project, run supabase/schema.sql once in its SQL
# editor, then fill these in. Without them the app uses in-memory demo storage.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Signs the login session cookie — any long random string
SESSION_SECRET=
